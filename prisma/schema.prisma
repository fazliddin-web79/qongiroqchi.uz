generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  email                 String                 @unique
  name                  String
  passwordHash          String?
  companyId             String?                @db.Uuid
  company               Company?               @relation(fields: [companyId], references: [id])
  roles                 UserRole[]
  auditLogs             AuditLog[]
  errorLogs             ErrorLog[]
  refreshTokens         RefreshToken[]
  assignedLeads         Lead[]                 @relation("AssignedLeads")
  campaigns             Campaign[]             @relation("CampaignCreator")
  reviewedCampaigns     Campaign[]             @relation("CampaignReviewer")
  uploadedAudioAssets   AudioAsset[]           @relation("AudioUploader")
  reviewedAudioAssets   AudioAsset[]           @relation("AudioReviewer")
  moderationReviews     ModerationReview[]
  notifications         Notification[]
  impersonationSessions ImpersonationSession[] @relation("ImpersonatingUser")
  leadHistory           LeadHistory[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?

  @@index([companyId])
}

model Company {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String
  slug                  String                 @unique
  status                CompanyStatus          @default(ACTIVE)
  suspendedAt           DateTime?
  suspensionReason      String?
  users                 User[]
  roles                 Role[]
  auditLogs             AuditLog[]
  errorLogs             ErrorLog[]
  leads                 Lead[]
  contacts              Contact[]
  groups                ContactGroup[]
  campaigns             Campaign[]
  calls                 Call[]
  audioAssets           AudioAsset[]
  moderationReviews     ModerationReview[]
  notifications         Notification[]
  impersonationSessions ImpersonationSession[]
  settings              CompanySetting?
  subscriptions         CompanySubscription[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
}

model CompanySetting {
  id                  String    @id @default(uuid()) @db.Uuid
  companyId           String    @unique @db.Uuid
  telegramBotToken    String?
  telegramChatId      String?
  defaultRetryCount   Int       @default(0)
  workingHours        Json      @default("{\"enabled\":false,\"start\":\"09:00\",\"end\":\"18:00\",\"days\":[1,2,3,4,5]}")
  callSpeedLimit      Int       @default(60)
  dailyCallLimit      Int       @default(1000)
  concurrentCallLimit Int       @default(5)
  retryFailed         Boolean   @default(true)
  retryBusy           Boolean   @default(true)
  retryUnanswered     Boolean   @default(true)
  defaultLanguage     String    @default("uz")
  timezone            String    @default("Asia/Tashkent")
  company             Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
}

model Plan {
  id            String                @id @default(uuid()) @db.Uuid
  name          String                @unique
  monthlyPrice  Decimal               @db.Decimal(12, 2)
  callLimit     Int
  userLimit     Int
  campaignLimit Int
  features      Json                  @default("{}")
  subscriptions CompanySubscription[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  deletedAt     DateTime?
}

model CompanySubscription {
  id        String             @id @default(uuid()) @db.Uuid
  companyId String             @db.Uuid
  planId    String             @db.Uuid
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime           @default(now())
  endsAt    DateTime
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan      Plan               @relation(fields: [planId], references: [id])
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@index([startsAt, endsAt])
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        RoleName
  description String?
  companyId   String?      @db.Uuid
  company     Company?     @relation(fields: [companyId], references: [id])
  permissions Permission[]
  users       UserRole[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@unique([name, companyId])
  @@index([companyId])
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  description String?
  roles       Role[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  roleId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, roleId])
  @@index([roleId])
}

model AuditLog {
  id        String    @id @default(uuid()) @db.Uuid
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  userId    String?   @db.Uuid
  companyId String?   @db.Uuid
  user      User?     @relation(fields: [userId], references: [id])
  company   Company?  @relation(fields: [companyId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([companyId])
}

model ErrorLog {
  id         String    @id @default(uuid()) @db.Uuid
  message    String
  stack      String?
  context    Json?
  route      String?
  method     String?
  statusCode Int?
  resolvedAt DateTime?
  userId     String?   @db.Uuid
  companyId  String?   @db.Uuid
  user       User?     @relation(fields: [userId], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([userId])
  @@index([companyId])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model Lead {
  id           String        @id @default(uuid()) @db.Uuid
  companyId    String        @db.Uuid
  campaignId   String?       @db.Uuid
  contactId    String?       @db.Uuid
  callId       String?       @unique @db.Uuid
  source       String        @default("MANUAL")
  status       LeadStatus    @default(NEW)
  assignedToId String?       @db.Uuid
  note         String?
  callbackAt   DateTime?
  company      Company       @relation(fields: [companyId], references: [id])
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  call         Call?         @relation(fields: [callId], references: [id])
  assignedTo   User?         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  history      LeadHistory[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([companyId])
  @@index([campaignId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
  @@index([callbackAt])
}

model LeadHistory {
  id         String      @id @default(uuid()) @db.Uuid
  leadId     String      @db.Uuid
  userId     String?     @db.Uuid
  action     String
  fromStatus LeadStatus?
  toStatus   LeadStatus?
  note       String?
  metadata   Json?
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  @@index([leadId])
  @@index([userId])
}

model Contact {
  id          String        @id @default(uuid()) @db.Uuid
  companyId   String        @db.Uuid
  fullName    String
  phone       String
  extraFields Json          @default("{}")
  groupId     String?       @db.Uuid
  status      ContactStatus @default(ACTIVE)
  company     Company       @relation(fields: [companyId], references: [id])
  group       ContactGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  calls       Call[]
  leads       Lead[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([companyId])
  @@index([companyId, phone])
  @@index([groupId])
  @@index([status])
}

model ContactGroup {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  name        String
  description String?
  company     Company    @relation(fields: [companyId], references: [id])
  contacts    Contact[]
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@index([companyId])
}

model Campaign {
  id                String             @id @default(uuid()) @db.Uuid
  companyId         String             @db.Uuid
  name              String
  description       String?
  audioUrl          String?
  audioAssetId      String?            @db.Uuid
  contactGroupId    String             @db.Uuid
  status            CampaignStatus     @default(DRAFT)
  rejectionReason   String?
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewedById      String?            @db.Uuid
  startTime         DateTime?
  retryEnabled      Boolean            @default(false)
  retryCount        Int                @default(0)
  ivrSettings       Json               @default("{}")
  createdById       String             @db.Uuid
  company           Company            @relation(fields: [companyId], references: [id])
  contactGroup      ContactGroup       @relation(fields: [contactGroupId], references: [id])
  createdBy         User               @relation("CampaignCreator", fields: [createdById], references: [id])
  reviewedBy        User?              @relation("CampaignReviewer", fields: [reviewedById], references: [id])
  audioAsset        AudioAsset?        @relation(fields: [audioAssetId], references: [id])
  moderationReviews ModerationReview[]
  calls             Call[]
  leads             Lead[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([contactGroupId])
  @@index([createdById])
  @@index([audioAssetId])
  @@index([reviewedById])
  @@index([status])
  @@index([startTime])
}

model AudioAsset {
  id                String             @id @default(uuid()) @db.Uuid
  companyId         String             @db.Uuid
  url               String
  originalName      String
  mimeType          String
  sizeBytes         Int
  durationSeconds   Int?
  status            AudioReviewStatus  @default(PENDING_REVIEW)
  rejectionReason   String?
  createdById       String             @db.Uuid
  reviewedById      String?            @db.Uuid
  reviewedAt        DateTime?
  company           Company            @relation(fields: [companyId], references: [id])
  createdBy         User               @relation("AudioUploader", fields: [createdById], references: [id])
  reviewedBy        User?              @relation("AudioReviewer", fields: [reviewedById], references: [id])
  campaigns         Campaign[]
  moderationReviews ModerationReview[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  @@index([companyId])
  @@index([createdById])
  @@index([reviewedById])
  @@index([status])
}

model ModerationReview {
  id           String                @id @default(uuid()) @db.Uuid
  subjectType  ModerationSubjectType
  decision     ModerationDecision
  reason       String?
  metadata     Json?
  companyId    String                @db.Uuid
  reviewerId   String                @db.Uuid
  campaignId   String?               @db.Uuid
  audioAssetId String?               @db.Uuid
  company      Company               @relation(fields: [companyId], references: [id])
  reviewer     User                  @relation(fields: [reviewerId], references: [id])
  campaign     Campaign?             @relation(fields: [campaignId], references: [id])
  audioAsset   AudioAsset?           @relation(fields: [audioAssetId], references: [id])
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?

  @@index([companyId])
  @@index([reviewerId])
  @@index([campaignId])
  @@index([audioAssetId])
  @@index([subjectType, decision])
}

model Notification {
  id              String               @id @default(uuid()) @db.Uuid
  audience        NotificationAudience
  type            String
  title           String
  message         String
  metadata        Json?
  companyId       String?              @db.Uuid
  recipientUserId String?              @db.Uuid
  readAt          DateTime?
  company         Company?             @relation(fields: [companyId], references: [id])
  recipientUser   User?                @relation(fields: [recipientUserId], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  @@index([audience])
  @@index([companyId])
  @@index([recipientUserId])
  @@index([readAt])
}

model ImpersonationSession {
  id             String    @id @default(uuid()) @db.Uuid
  platformUserId String    @db.Uuid
  companyId      String    @db.Uuid
  reason         String?
  expiresAt      DateTime
  endedAt        DateTime?
  platformUser   User      @relation("ImpersonatingUser", fields: [platformUserId], references: [id])
  company        Company   @relation(fields: [companyId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([platformUserId])
  @@index([companyId])
  @@index([expiresAt])
}

model Call {
  id             String     @id @default(uuid()) @db.Uuid
  companyId      String     @db.Uuid
  campaignId     String     @db.Uuid
  contactId      String     @db.Uuid
  phone          String
  providerCallId String?
  status         CallStatus @default(PENDING)
  duration       Int?
  pressedKey     String?
  recordingUrl   String?
  errorMessage   String?
  attemptCount   Int        @default(0)
  startedAt      DateTime?
  endedAt        DateTime?
  company        Company    @relation(fields: [companyId], references: [id])
  campaign       Campaign   @relation(fields: [campaignId], references: [id])
  contact        Contact    @relation(fields: [contactId], references: [id])
  lead           Lead?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([campaignId, contactId])
  @@index([companyId])
  @@index([campaignId])
  @@index([contactId])
  @@index([providerCallId])
  @@index([status])
  @@index([createdAt])
}

enum RoleName {
  SUPER_ADMIN
  PLATFORM_ADMIN
  MODERATOR
  SUPPORT
  BILLING_MANAGER
  COMPANY_OWNER
  COMPANY_ADMIN
  MANAGER
  OPERATOR
  ANALYST
  ACCOUNTANT
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum ContactStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  AUDIO_UPLOADED
  PENDING_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  SCHEDULED
  RUNNING
  PAUSED
  CANCELED
  COMPLETED
  FAILED
}

enum AudioReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ModerationSubjectType {
  AUDIO
  CAMPAIGN
}

enum ModerationDecision {
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum NotificationAudience {
  PLATFORM
  COMPANY
  USER
}

enum CallStatus {
  PENDING
  CALLING
  ANSWERED
  NOT_ANSWERED
  BUSY
  FAILED
  COMPLETED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  SOLD
  ARCHIVED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}
