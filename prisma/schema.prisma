generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  name          String
  passwordHash  String?
  companyId     String?        @db.Uuid
  company       Company?       @relation(fields: [companyId], references: [id])
  roles         UserRole[]
  auditLogs     AuditLog[]
  errorLogs     ErrorLog[]
  refreshTokens RefreshToken[]
  assignedLeads Lead[]         @relation("AssignedLeads")
  campaigns     Campaign[]     @relation("CampaignCreator")
  leadHistory   LeadHistory[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([companyId])
}

model Company {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  slug      String         @unique
  users     User[]
  roles     Role[]
  auditLogs AuditLog[]
  errorLogs ErrorLog[]
  leads     Lead[]
  contacts  Contact[]
  groups    ContactGroup[]
  campaigns Campaign[]
  calls     Call[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        RoleName
  description String?
  companyId   String?      @db.Uuid
  company     Company?     @relation(fields: [companyId], references: [id])
  permissions Permission[]
  users       UserRole[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@unique([name, companyId])
  @@index([companyId])
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  description String?
  roles       Role[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  roleId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, roleId])
  @@index([roleId])
}

model AuditLog {
  id        String    @id @default(uuid()) @db.Uuid
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  userId    String?   @db.Uuid
  companyId String?   @db.Uuid
  user      User?     @relation(fields: [userId], references: [id])
  company   Company?  @relation(fields: [companyId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([companyId])
}

model ErrorLog {
  id         String    @id @default(uuid()) @db.Uuid
  message    String
  stack      String?
  context    Json?
  route      String?
  method     String?
  statusCode Int?
  resolvedAt DateTime?
  userId     String?   @db.Uuid
  companyId  String?   @db.Uuid
  user       User?     @relation(fields: [userId], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([userId])
  @@index([companyId])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model Lead {
  id           String        @id @default(uuid()) @db.Uuid
  companyId    String        @db.Uuid
  campaignId   String?       @db.Uuid
  contactId    String?       @db.Uuid
  callId       String?       @unique @db.Uuid
  source       String        @default("MANUAL")
  status       LeadStatus    @default(NEW)
  assignedToId String?       @db.Uuid
  note         String?
  callbackAt   DateTime?
  company      Company       @relation(fields: [companyId], references: [id])
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  call         Call?         @relation(fields: [callId], references: [id])
  assignedTo   User?         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  history      LeadHistory[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([companyId])
  @@index([campaignId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
  @@index([callbackAt])
}

model LeadHistory {
  id         String      @id @default(uuid()) @db.Uuid
  leadId     String      @db.Uuid
  userId     String?     @db.Uuid
  action     String
  fromStatus LeadStatus?
  toStatus   LeadStatus?
  note       String?
  metadata   Json?
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  @@index([leadId])
  @@index([userId])
}

model Contact {
  id          String        @id @default(uuid()) @db.Uuid
  companyId   String        @db.Uuid
  fullName    String
  phone       String
  extraFields Json          @default("{}")
  groupId     String?       @db.Uuid
  status      ContactStatus @default(ACTIVE)
  company     Company       @relation(fields: [companyId], references: [id])
  group       ContactGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  calls       Call[]
  leads       Lead[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([companyId])
  @@index([companyId, phone])
  @@index([groupId])
  @@index([status])
}

model ContactGroup {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String     @db.Uuid
  name        String
  description String?
  company     Company    @relation(fields: [companyId], references: [id])
  contacts    Contact[]
  campaigns   Campaign[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@index([companyId])
}

model Campaign {
  id             String         @id @default(uuid()) @db.Uuid
  companyId      String         @db.Uuid
  name           String
  description    String?
  audioUrl       String?
  contactGroupId String         @db.Uuid
  status         CampaignStatus @default(DRAFT)
  startTime      DateTime?
  retryEnabled   Boolean        @default(false)
  retryCount     Int            @default(0)
  ivrSettings    Json           @default("{}")
  createdById    String         @db.Uuid
  company        Company        @relation(fields: [companyId], references: [id])
  contactGroup   ContactGroup   @relation(fields: [contactGroupId], references: [id])
  createdBy      User           @relation("CampaignCreator", fields: [createdById], references: [id])
  calls          Call[]
  leads          Lead[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  @@index([companyId])
  @@index([contactGroupId])
  @@index([createdById])
  @@index([status])
  @@index([startTime])
}

model Call {
  id           String     @id @default(uuid()) @db.Uuid
  companyId    String     @db.Uuid
  campaignId   String     @db.Uuid
  contactId    String     @db.Uuid
  phone        String
  status       CallStatus @default(PENDING)
  duration     Int?
  pressedKey   String?
  recordingUrl String?
  errorMessage String?
  attemptCount Int        @default(0)
  startedAt    DateTime?
  endedAt      DateTime?
  company      Company    @relation(fields: [companyId], references: [id])
  campaign     Campaign   @relation(fields: [campaignId], references: [id])
  contact      Contact    @relation(fields: [contactId], references: [id])
  lead         Lead?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([campaignId, contactId])
  @@index([companyId])
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
  @@index([createdAt])
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum ContactStatus {
  ACTIVE
  BLOCKED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum CallStatus {
  PENDING
  CALLING
  ANSWERED
  NOT_ANSWERED
  BUSY
  FAILED
  COMPLETED
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  SOLD
  ARCHIVED
}
